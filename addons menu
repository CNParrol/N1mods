    /* ========= SNAKE GAME ========= */
const canvas = $("#snakeCanvas");
const ctx = canvas.getContext("2d");
const grid = 12;
const tileCount = 20;

let snake, food, dx, dy, snakeLoop;
let score = 0;
let started = false;

function startSnake(){
    canvas.style.display = "block";

    snake = [{x:10*grid,y:10*grid}];
    dx = 0;
    dy = 0;
    score = 0;
    started = false;

    spawnFood();
    drawSnake();

    clearInterval(snakeLoop);
}

function spawnFood(){
    food = {
        x:Math.floor(Math.random()*tileCount)*grid,
        y:Math.floor(Math.random()*tileCount)*grid
    };
}

function updateSnake(){
    const head = {x:snake[0].x+dx,y:snake[0].y+dy};
    snake.unshift(head);

    if(head.x===food.x && head.y===food.y){
        score++;
        spawnFood();
    } else {
        snake.pop();
    }

    if(head.x<0||head.y<0||head.x>=canvas.width||head.y>=canvas.height||
       snake.slice(1).some(s=>s.x===head.x&&s.y===head.y)){
        clearInterval(snakeLoop);
        alert("Game Over 💀 Score: "+score);
        canvas.style.display="none";
        return;
    }

    drawSnake();
}

function drawGrid(){
    ctx.strokeStyle = "#222";
    for(let i=0;i<=tileCount;i++){
        ctx.beginPath();
        ctx.moveTo(i*grid,0);
        ctx.lineTo(i*grid,canvas.height);
        ctx.stroke();

        ctx.beginPath();
        ctx.moveTo(0,i*grid);
        ctx.lineTo(canvas.width,i*grid);
        ctx.stroke();
    }
}

function drawSnake(){
    ctx.fillStyle="#000";
    ctx.fillRect(0,0,canvas.width,canvas.height);

    drawGrid();

    ctx.fillStyle="lime";
    snake.forEach(s=>ctx.fillRect(s.x,s.y,grid-1,grid-1));

    ctx.fillStyle="red";
    ctx.fillRect(food.x,food.y,grid-1,grid-1);

    ctx.fillStyle="#fff";
    ctx.font="14px Arial";
    ctx.fillText("Score: "+score,8,16);

    if(!started){
        ctx.fillStyle="rgba(0,0,0,.6)";
        ctx.fillRect(0,0,canvas.width,canvas.height);

        ctx.fillStyle="#fff";
        ctx.textAlign="center";
        ctx.fillText("Press any key to start",canvas.width/2,canvas.height/2);
        ctx.textAlign="left";
    }
}

document.addEventListener("keydown",e=>{
    if(state.tab!=="game") return;
    if(canvas.style.display==="none") return;

    if(!started){
        started = true;
        snakeLoop = setInterval(updateSnake,100);
    }

    if(e.key==="ArrowUp" && dy===0){dx=0;dy=-grid;}
    if(e.key==="ArrowDown" && dy===0){dx=0;dy=grid;}
    if(e.key==="ArrowLeft" && dx===0){dx=-grid;dy=0;}
    if(e.key==="ArrowRight" && dx===0){dx=grid;dy=0;}
});

$("#launchSnake").onclick=startSnake;


