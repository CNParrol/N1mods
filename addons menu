    /* ========= VSYNC ========= */
    let fpsLimit = null;
    function applyVsync() {
        fpsLimit =
            state.vsync === "60" ? 60 :
            state.vsync === "120" ? 120 :
            state.vsync === "240" ? 240 :
            null;
    }
    applyVsync();

    let last = performance.now();
    const _raf = window.requestAnimationFrame;
    window.requestAnimationFrame = function (cb) {
        if (!fpsLimit) return _raf(cb);
        const now = performance.now();
        const interval = 1000 / fpsLimit;
        if (now - last >= interval) {
            last = now;
            cb(now);
        } else {
            _raf(() => window.requestAnimationFrame(cb));
        }
    };

